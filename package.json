{
  "name": "better-auth-nostr",
  "description": "Nostr (NIP-98) plugin for Better Auth",
  "version": "0.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build.ts",
    "build:js": "bun run build.ts --no-dts",
    "build:dts": "tsc -p tsconfig.build.json",
    "dev": "bun run build.ts --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "auth",
    "nostr",
    "nip-98",
    "typescript",
    "better-auth",
    "bun"
  ],
  "dependencies": {
    "nostr-tools": "^2.23.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "^1.3.14",
    "better-auth": "^1.6.18",
    "typescript": "^5.9.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@better-fetch/fetch": "^1.3.1",
    "better-auth": "^1.4.0",
    "nanostores": "^1.3.0",
    "zod": "^3.23.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "nanostores": {
      "optional": true
    }
  },
  "homepage": "https://github.com/leon-wbr/better-auth-nostr#readme",
  "bugs": {
    "url": "https://github.com/leon-wbr/better-auth-nostr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leon-wbr/better-auth-nostr.git"
  },
  "author": "Leon Weber",
  "license": "MIT"
}
